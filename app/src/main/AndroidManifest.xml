<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android">

    <!-- Usage Stats - to track which app is being used -->
    <uses-permission android:name="android.permission.PACKAGE_USAGE_STATS" />
    <!-- Overlay - to show blocking screen over other apps -->
    <uses-permission android:name="android.permission.SYSTEM_ALERT_WINDOW" />
    <!-- Keep service running in background -->
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE" />
    <!-- Start on phone reboot -->
    <uses-permission android:name="android.permission.RECEIVE_BOOT_COMPLETED" />
    <!-- Show notifications (Android 13+) -->
    <uses-permission android:name="android.permission.POST_NOTIFICATIONS" />
    <!-- Keep running without battery restrictions -->
    <uses-permission android:name="android.permission.REQUEST_IGNORE_BATTERY_OPTIMIZATIONS" />

    <application
        android:allowBackup="true"
        android:icon="@mipmap/ic_launcher"
        android:roundIcon="@mipmap/ic_launcher_round"
        android:label="@string/app_name"
        android:theme="@style/Theme.FocusGuard"
        android:supportsRtl="true">

        <!-- Main Screen: App List -->
        <activity
            android:name=".MainActivity"
            android:exported="true"
            android:label="@string/app_name">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>

        <!-- App Settings Screen -->
        <activity
            android:name=".AppSettingsActivity"
            android:exported="false"
            android:label="App Settings"
            android:parentActivityName=".MainActivity" />

        <!-- Blocking Screen (shown when time limit exceeded) -->
        <activity
            android:name=".BlockerActivity"
            android:exported="false"
            android:label="Time Limit Reached"
            android:launchMode="singleTop"
            android:theme="@style/Theme.FocusGuard.Blocker"
            android:excludeFromRecents="true" />

        <!-- Background Monitoring Service -->
        <service
            android:name=".MonitorService"
            android:exported="false"
            android:stopWithTask="false" />

        <!-- Auto-start after phone reboot -->
        <receiver
            android:name=".BootReceiver"
            android:exported="true">
            <intent-filter>
                <action android:name="android.intent.action.BOOT_COMPLETED" />
                <action android:name="android.intent.action.MY_PACKAGE_REPLACED" />
            </intent-filter>
        </receiver>

    </application>
</manifest>
